<script>
      fetch('/count', {
					method: 'post',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify({
						count: <%= randomCount %> + 1
					})
				})
				.then(response => response.text()) // রেসপন্সকে টেক্সট হিসেবে নিন
				.then(data => {
					console.log(data);
				})
				.catch(error => {
					console.error('Error:', error);
				});
</script>