<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= hadding %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow">
  <meta name="keywords" content="<%= keywords %>" />
  
  <link rel="icon" href="<%= img %>"/>
  <link rel="canonical" href="<%= url %>" />
  
  
  <!-- OG -->
  <meta property="og:title" content="<%= hadding %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:image" content="<%= img %>">
  <meta property="og:url" content="<%= url %>">
  <meta property="og:type" content="website">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= hadding %>">
  <meta name="twitter:description" content="<%= description %>">
  <meta name="twitter:image" content="<%= img %>">

  <style>
    /* Reset & Base */
    * { 
      box-sizing: border-box; 
      margin:0; 
      padding:0; 
    }
    
    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: radial-gradient(ellipse at top, #0c0c0c 0%, #050505 100%);
      color:#fff; 
      line-height:1.6;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Animated background */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: 
        radial-gradient(circle at 20% 30%, rgba(77, 163, 255, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(255, 77, 164, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 40% 80%, rgba(255, 184, 77, 0.03) 0%, transparent 50%);
      z-index: -1;
    }

    /* Header placeholder */
    header { 
      background: linear-gradient(135deg, #111 0%, #1a1a1a 100%);
      padding: 18px 20px;
      font-size: 24px;
      font-weight: 800;
      letter-spacing: 1.2px;
      position: relative;
      overflow: hidden;
      border-bottom: 2px solid #4da3ff;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
    }
    
    header::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(77, 163, 255, 0.2), transparent);
      animation: shimmer 8s infinite;
    }
    
    @keyframes shimmer {
      0% { left: -100%; }
      100% { left: 100%; }
    }

    /* Latest movies section - Bountiful Style */
    .latest-movies {
      background: linear-gradient(90deg, rgba(15, 15, 15, 0.9) 0%, rgba(30, 30, 30, 0.9) 100%);
      padding: 20px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      border-bottom: 1px solid rgba(77, 163, 255, 0.2);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      position: relative;
      margin-top: 40px;
    }
    
    .latest-movies::before {
      content: 'LATEST ADDITIONS';
      position: absolute;
      top: -12px;
      left: 30px;
      background: linear-gradient(90deg, #4da3ff, #ff4da3);
      padding: 4px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      color: white;
      box-shadow: 0 4px 10px rgba(77, 163, 255, 0.3);
      
      margin-top: -10px;
    }
    
    .latest-movies a {
      background: linear-gradient(135deg, #2e2e2e 0%, #1a1a1a 100%);
      padding: 10px 18px;
      border-radius: 12px;
      color: #fff;
      font-weight: 600;
      font-size: 15px;
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(77, 163, 255, 0.3);
      position: relative;
      overflow: hidden;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
      display: flex;
      align-items: center;
      width: 300px;
    }
    
    .latest-movies a::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(77, 163, 255, 0.2), transparent);
      transition: left 0.7s;
    }
    
    .latest-movies a:hover {
      background: linear-gradient(135deg, #4da3ff 0%, #1a5bff 100%);
      color: #fff;
      transform: translateY(-5px) scale(1.05);
      box-shadow: 0 10px 20px rgba(77, 163, 255, 0.4);
      border-color: #4da3ff;
    }
    
    .latest-movies a:hover::before {
      left: 100%;
    }
    
    .latest-movies a::after {
      content: '🔥';
      margin-right: 8px;
      filter: drop-shadow(0 0 3px rgba(255, 100, 0, 0.7));
    }

    /* Search query */
    .search-result {
      padding: 20px;
      font-size: 20px;
      color: #fff;
      font-weight: 600;
      text-align: center;
      background: linear-gradient(90deg, rgba(77, 163, 255, 0.1) 0%, rgba(255, 77, 164, 0.1) 100%);
      margin: 20px auto;
      border-radius: 15px;
      max-width: 90%;
      position: relative;
      overflow: hidden;
      border-left: 5px solid #4da3ff;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
    }
    
    .search-result::before {
      content: '🔍';
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 24px;
      opacity: 0.7;
    }
    
    .search-result::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
      animation: searchShine 3s infinite;
    }
    
    @keyframes searchShine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    /* Movie grid - Enhanced Bountiful Style */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 28px;
      padding: 30px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .card {
      position: relative;
      overflow: hidden;
      border-radius: 18px;
      background: linear-gradient(145deg, #1b1b1b 0%, #0f0f0f 100%);
      text-decoration: none;
      color: #fff;
      transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(255, 255, 255, 0.05);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    
    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(77, 163, 255, 0.1) 0%, rgba(255, 77, 164, 0.1) 100%);
      opacity: 0;
      transition: opacity 0.5s;
      z-index: 1;
      pointer-events: none;
    }

    .card img {
      width: 100%;
      display: block;
      transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      filter: brightness(0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Overlay effect */
    .card h3 {
      position: relative;
      padding: 20px 15px;
      background: linear-gradient(transparent, rgba(10, 10, 10, 0.95));
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      transition: all 0.4s;
      flex-grow: 1;
      display: flex;
      align-items: center;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
      z-index: 2;
      line-height: 1.4;
    }
    
    .card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, #4da3ff, #ff4da3);
      transform: scaleX(0);
      transition: transform 0.5s;
      z-index: 3;
    }

    .card:hover {
      transform: translateY(-12px) scale(1.03);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(77, 163, 255, 0.3);
      border-color: rgba(77, 163, 255, 0.5);
    }
    
    .card:hover::before {
      opacity: 1;
    }

    .card:hover img {
      transform: scale(1.12);
      filter: brightness(1.1);
    }

    .card:hover h3 {
      background: linear-gradient(transparent, rgba(20, 20, 40, 0.95));
      color: #4da3ff;
      transform: translateY(-5px);
    }
    
    .card:hover::after {
      transform: scaleX(1);
    }
    
    /* Rating badge */
    .card .rating {
      position: absolute;
      top: 15px;
      right: 15px;
      background: linear-gradient(135deg, #ff4da3, #ff9a3d);
      color: white;
      font-weight: 800;
      font-size: 14px;
      padding: 6px 10px;
      border-radius: 10px;
      z-index: 3;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      gap: 4px;
    }
    
    .card .rating::before {
      content: '★';
      font-size: 12px;
      color: gold;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .grid { 
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); 
        gap: 24px; 
        padding: 24px; 
      }
      .latest-movies a { font-size: 14px; padding: 9px 16px; }
      .search-result { font-size: 18px; }
    }

    @media (max-width: 768px) {
      .grid { 
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); 
        gap: 20px; 
        padding: 20px; 
      }
      .card h3 { font-size: 16px; padding: 16px 12px; }
      .latest-movies { padding: 18px; gap: 12px; }
      .latest-movies a { font-size: 13px; padding: 8px 14px; }
      .search-result { font-size: 16px; padding: 16px; }
      header { font-size: 20px; padding: 16px 18px; }
    }

    @media (max-width: 480px) {
      .grid { 
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); 
        gap: 16px; 
        padding: 16px; 
      }
      .card h3 { font-size: 14px; padding: 14px 10px; }
      .card .rating { font-size: 12px; padding: 4px 8px; top: 10px; right: 10px; }
      .latest-movies a { font-size: 12px; padding: 7px 12px; }
      .search-result { font-size: 15px; padding: 14px; }
      header { font-size: 18px; padding: 14px 16px; }
    }
    
    /* Footer */
    footer {
      text-align: center;
      padding: 30px 20px;
      color: #aaa;
      font-size: 14px;
      border-top: 1px solid rgba(77, 163, 255, 0.2);
      margin-top: 40px;
      background: linear-gradient(transparent, rgba(10, 10, 10, 0.9));
    }
  </style>
</head>
<body>

<%- include('partials/header') %>


<% if (query) { %>
  <div class="search-result">
    Search result for: "<%= query %>"
  </div>
<% } %>


<div class="latest-movies">
  <% latest.forEach(item => { %>
    <a href="/movie/<%= item.id %>">🔥 <%= item.hadding %></a>
  <% }) %>
</div>

<div class="grid">
  <% data.forEach(movie => { %>
    <a href="/movie/<%= movie.id %>" class="card">
      <!-- Adding a rating badge for each movie -->
      <div class="rating"><%= (Math.random() * 2 + 8).toFixed(1) %></div>
      <img src="<%= movie.img %>" loading="lazy" alt="<%= movie.hadding %>">
      <h3><%= movie.hadding %></h3>
    </a>
  <% }) %>
</div>


<footer>
  &copy; 2026 Movie Collection. All rights reserved.
</footer>

</body>
</html>